src/ui/HUD.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\isaac.dir\build.make CMakeFiles/isaac.dir/src/ui/HUD.cpp.o
.PHONY : src/ui/HUD.cpp.o

src/ui/HUD.i: src/ui/HUD.cpp.i
.PHONY : src/ui/HUD.i

# target to preprocess a source file
src/ui/HUD.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\isaac.dir\build.make CMakeFiles/isaac.dir/src/ui/HUD.cpp.i
.PHONY : src/ui/HUD.cpp.i

src/ui/HUD.s: src/ui/HUD.cpp.s
.PHONY : src/ui/HUD.s

# target to generate assembly for a file
src/ui/HUD.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\isaac.dir\build.make CMakeFiles/isaac.dir/src/ui/HUD.cpp.s
.PHONY : src/ui/HUD.cpp.s

